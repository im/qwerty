@import './var'
@import url('//at.alicdn.com/t/font_2921227_pdylsm8gw4r.css')

::-webkit-scrollbar
    width 0px
::-webkit-scrollbar-track
    border-radius 2px
:-webkit-scrollbar-track-piece
    border-radius 2px
::-webkit-scrollbar-thumb
    border-radius 2px
    background rgba(233, 233, 233, 0.51)
*
    padding 0
    margin 0
    box-sizing border-box
html, body
    width 100%
    height 100%
ul, li
    list-style none
label
    position relative
    padding-left 5px
