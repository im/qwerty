.wrap
    height 100%
    // overflow-y auto
    background rgba(255, 255, 255, 0.7)
    position fixed
    left -400px
    top 0
    width 400px
    transition 0.4s
    &.open
        left 0
        .handle
            .iconfont
                transform rotate(180deg)
    .handle
        width 25px
        height 40px
        position absolute
        line-height 40px
        text-align center
        font-weight bold
        right -25px
        top calc(50% - 20px)
        cursor pointer
        background rgba(255, 255, 255, 0.7)
        border-top-right-radius 4px
        border-bottom-right-radius 4px
        transition 0.4s
        .iconfont
            display block
            transition 0.4s
.content
    display flex
    height 100%
.list
    // display flex
    // flex-wrap wrap
    height 100%
    overflow-y auto
    width calc(100% - 40px)
    // align-content flex-start
.item
    margin 5px
    padding 10px 0
    // width calc(20% - 10px)
    width 100%
    color #2c3e50
    background #ccc
    text-align center
    transition 0.3s
    cursor pointer
    border-radius 4px
    height 80px
    .name, .length
        font-weight bold
    .desc
        font-size 12px
    .length
        font-size 12px
    .name, .desc
        display block
        overflow hidden
        text-overflow ellipsis
        white-space nowrap
        width 100%
        text-align center
    &:hover
        opacity 0.8
.nav
    .btn
        width 30px
        margin-bottom 10px
        padding 10px 0
        background #ccc
        text-align center
        transition all 0.4s
        font-size 12px
        cursor pointer
        font-size 16px
        &.active
            font-weight bold
            background #eb722c
            color #fff
        &:hover
            opacity 0.8